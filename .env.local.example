NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SERPAPI_API_KEY=your-serpapi-api-key
TURNSTILE_SITEKEY=your-turnstile-sitekey-here

# Stripe (Phase 1 monetization)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_APP_URL=https://shrinekeep.com

# Moderation (server-only — ban user, cancel Pro, purge storage, notify via Resend)
MODERATION_SECRET=generate-a-long-random-string
RESEND_API_KEY=re_...
MODERATION_EMAIL_FROM=noreply@your-verified-domain.com
# Optional: comma-separated browser origins allowed to call moderation APIs cross-origin
# (e.g. local GUI → production API). Example:
MODERATION_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
